{
  "rewrites": [
    {
      "source": "/api/x/:path*",
      "destination": "/api/x?path=:path*"
    },
    {
      "source": "/api/twitter/:path*",
      "destination": "/api/twitter?path=:path*"
    },
    {
      "source": "/api/supabase/:path*",
      "destination": "/api/supabase?path=:path*"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
