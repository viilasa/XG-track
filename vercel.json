{
  "rewrites": [
    {
      "source": "/api/x/:path*",
      "destination": "/api/x?path=:path*"
    },
    {
      "source": "/api/twitter/:path*",
      "destination": "/api/twitter?path=:path*"
    },
    {
      "source": "/sb/:path*",
      "destination": "https://sofmnrkibynnjeeoichz.supabase.co/:path*"
    },
    {
      "source": "/((?!api/|sb/).*)",
      "destination": "/index.html"
    }
  ]
}
